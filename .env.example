# ============================================================
# ClearFunds — environment variables
# Copy to `.env.local` for local dev, or set in Vercel project settings.
# Anything prefixed VITE_ is exposed to the browser (safe for public keys).
# Server-only secrets (no VITE_ prefix) are set as Supabase Edge Function
# secrets, NEVER in the frontend.
# ============================================================

# ---- Data adapter selection --------------------------------------------
# Leave Supabase vars blank to run on the localStorage dev adapter (default).
# Set both Supabase vars to switch the app to the Supabase adapter.
# Force a specific adapter regardless: "local" | "supabase".
# VITE_DATA_ADAPTER=local

# ---- Supabase (frontend / public) --------------------------------------
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Seed demo data for brand-new Supabase users (default true).
# VITE_SEED_NEW_USERS=true

# ---- Stripe (future monetization; UNUSED at MVP) -----------------------
# VITE_STRIPE_PUBLISHABLE_KEY=

# ========================================================================
# Server-only secrets — DO NOT put these in the frontend / Vercel client.
# Set via: supabase secrets set KEY=value
# ========================================================================
# SUPABASE_SERVICE_ROLE_KEY=     # auto-available inside Edge Functions
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
